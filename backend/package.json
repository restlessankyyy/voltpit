{
  "name": "tesla-dash-backend",
  "version": "1.0.0",
  "description": "Tesla Fleet API bridge: OAuth, polling/telemetry, and a WebSocket hub that streams vehicle state to the Tesla Dash iPhone app.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "keys": "tsx src/scripts/generateKeys.ts",
    "telemetry:sample": "tsx src/scripts/sampleTelemetry.ts"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/identity": "^4.13.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
