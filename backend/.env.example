# ───────────────────────────────────────────────────────────────────────────
# Tesla Dash backend configuration
# Copy to `.env` and fill in. Simulator mode needs nothing else.
# ───────────────────────────────────────────────────────────────────────────

# Data source: "simulator" (fake drive, no Tesla account) or "tesla" (real car).
SOURCE=simulator

# Port the HTTP + WebSocket server listens on.
PORT=8080

# How often to poll Tesla vehicle_data while driving, in milliseconds.
# Tesla discourages aggressive polling. 2000–5000ms is reasonable for a drive.
# (Ignored in simulator mode, which emits at a fixed cadence.)
POLL_INTERVAL_MS=2500

# ── Tesla Fleet API (only needed when SOURCE=tesla) ─────────────────────────
# See docs/TESLA_FLEET_API_SETUP.md for how to obtain all of these.

# OAuth application credentials from the Tesla developer dashboard.
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# Must exactly match a redirect URI registered on your Tesla app.
TESLA_REDIRECT_URI=http://localhost:8080/auth/callback

# The public domain you registered (where the public key is hosted).
TESLA_APP_DOMAIN=

# Region base URL for the Fleet API. Pick the region of your Tesla account:
#   North America / Asia-Pacific: https://fleet-api.prd.na.vn.cloud.tesla.com
#   Europe / Middle East / Africa: https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_FLEET_BASE_URL=https://fleet-api.prd.na.vn.cloud.tesla.com

# OAuth scopes. vehicle_location is required to receive GPS coordinates.
TESLA_SCOPES=openid offline_access vehicle_device_data vehicle_location

# Optional: pin to a single car by VIN. If empty, the first vehicle is used.
TESLA_VIN=

# Where the OAuth tokens are cached on disk (gitignored).
TOKEN_STORE_PATH=./.tokens.json

# Units shown as the "primary" speed in the app payload: "mph" or "kph".
PRIMARY_UNIT=mph
